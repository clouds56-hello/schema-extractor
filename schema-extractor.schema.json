{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/opencode/schema-extractor.schema.json",
  "title": "schema-extractor manifest",
  "description": "Build manifest consumed by `schema-extractor gen` and the check integration test. Each target maps one or more JSONL inputs to a single generated .d.ts.",
  "type": "object",
  "required": ["targets"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional path to this JSON Schema for editor tooling."
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Target" }
    }
  },
  "definitions": {
    "Target": {
      "type": "object",
      "required": ["name", "input", "output"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Stable identifier used for logging and test naming."
        },
        "input": {
          "description": "JSONL glob(s). Supports ~ expansion and ** patterns; relative paths resolve against the manifest directory.",
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
          ]
        },
        "output": {
          "type": "string",
          "minLength": 1,
          "description": "Path the generated .d.ts is written to. Relative paths resolve against the manifest directory."
        },
        "options": {
          "type": "object",
          "description": "Per-target ExtractorOptions overrides. CLI flags still take precedence.",
          "additionalProperties": false,
          "properties": {
            "rootName": { "type": "string", "minLength": 1 },
            "userTagKey": { "type": ["string", "null"] },
            "header": { "type": "string" },
            "dedupHints": {
              "type": "array",
              "items": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": { "type": "string" }
              }
            },
            "recordHints": { "type": "array", "items": { "type": "string" } },
            "multiTagHints": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
