#!/usr/bin/env bash
# commit-msg hook: enforce Conventional Commits (optional scope, no body required).
# See agents.md "Commits" section for the policy.
set -e

msg_file="$1"
header=$(head -n1 "$msg_file")

# Allow merge / revert / fixup / squash commits unaltered.
case "$header" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

regex='^(feat|fix|chore|test|docs|refactor|style|perf|build|ci|revert)(\([a-z0-9_/-]+\))?!?: .+$'

if ! [[ "$header" =~ $regex ]]; then
  echo "" >&2
  echo "ERROR: commit message does not follow Conventional Commits." >&2
  echo "" >&2
  echo "  got: $header" >&2
  echo "" >&2
  echo "  required: <type>(optional-scope)!: <subject>" >&2
  echo "  types:    feat fix chore test docs refactor style perf build ci revert" >&2
  echo "  example:  feat(adapters): add codex-rollout replay support" >&2
  echo "" >&2
  exit 1
fi

# Subject length sanity check.
if [ ${#header} -gt 72 ]; then
  echo "ERROR: commit subject exceeds 72 chars (${#header})." >&2
  exit 1
fi
