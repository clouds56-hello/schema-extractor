{
  "$schema": "./schema-extractor.schema.json",
  "targets": [
    {
      "name": "codex",
      "input": "~/.codex/sessions/**/*.jsonl",
      "output": "examples/codex.d.ts",
      "options": { "rootName": "CodexRollout", "plugins": [] }
    },
    {
      "name": "copilot-chat",
      "input": "~/.config/Code/User/workspaceStorage/*/chatSessions/*.jsonl",
      "output": "examples/copilot-chat.d.ts",
      "options": { "rootName": "CopilotChat", "plugins": ["vscode"] }
    },
    {
      "name": "copilot-cli",
      "input": "~/.copilot/session-state/*/events.jsonl",
      "output": "examples/copilot-cli.d.ts",
      "options": { "rootName": "CopilotCli", "plugins": ["copilot-cli"] }
    }
  ]
}
