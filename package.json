{
  "name": "schema-extractor",
  "version": "0.1.0",
  "description": "Extract TypeScript schemas from JSON / JSONL streams",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./adapters/vscode-patch": "./src/adapters/vscode-patch.ts",
    "./adapters/codex-rollout": "./src/adapters/codex-rollout.ts"
  },
  "bin": {
    "schema-extractor": "bin/schema-extractor.ts"
  },
  "scripts": {
    "cli": "bun bin/schema-extractor.ts",
    "test": "bun test",
    "test:update": "UPDATE_GOLDEN=1 bun test",
    "regen:examples": "bun scripts/regen-examples.ts",
    "typecheck": "bunx tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "ci": "bun run typecheck && bun run lint && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "bun-types": "^1.3.13",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
