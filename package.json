{
  "name": "schema-extractor",
  "version": "0.1.2",
  "description": "Extract TypeScript schemas from JSON / JSONL streams",
  "license": "MIT",
  "author": "Clouds Flowing <clouds.flowing@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clouds56-hello/schema-extractor.git"
  },
  "homepage": "https://github.com/clouds56-hello/schema-extractor#readme",
  "bugs": {
    "url": "https://github.com/clouds56-hello/schema-extractor/issues"
  },
  "keywords": [
    "schema",
    "typescript",
    "jsonl",
    "json",
    "type-inference",
    "bun"
  ],
  "files": [
    "dist",
    "examples",
    "schema-extractor.schema.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./adapters/vscode-patch": {
      "types": "./dist/adapters/vscode-patch.d.ts",
      "import": "./dist/adapters/vscode-patch.js"
    },
    "./adapters/codex-rollout": {
      "types": "./dist/adapters/codex-rollout.d.ts",
      "import": "./dist/adapters/codex-rollout.js"
    }
  },
  "bin": {
    "schema-extractor": "./dist/bin/schema-extractor.js"
  },
  "scripts": {
    "cli": "bun bin/schema-extractor.ts",
    "test": "bun test",
    "test:update": "UPDATE_GOLDEN=1 bun test",
    "regen:examples": "bun bin/schema-extractor.ts gen",
    "bench": "bun scripts/bench.ts",
    "build": "bun scripts/build.ts",
    "prepublishOnly": "bun run ci && bun run build",
    "pack:dry": "bun run build && npm pack --dry-run",
    "typecheck": "bunx tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "ci": "bun run typecheck && bun run lint && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "bun-types": "^1.3.13",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
